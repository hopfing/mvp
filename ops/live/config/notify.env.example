# Discord webhooks for the live pipeline.
# Real file lives at ~/.config/mvp/notify.env (NOT version-controlled).
#
# IMPORTANT: no leading whitespace on these assignment lines.
# `source` treats `  VAR=...` as a command, not an assignment, so the
# vars silently end up empty. We hit this on 2026-04-30.

DISCORD_WEBHOOK_URL=
DISCORD_PREDICTIONS_WEBHOOK_URL=
